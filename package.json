{
  "name": "bluewirks-intelligence-cloud",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-industry AI-native knowledge & decision infrastructure on Google Cloud",
  "workspaces": [
    "platform-core/contracts",
    "platform-core/api",
    "platform-core/worker",
    "platform-core/ingestion",
    "platform-core/vector-engine",
    "platform-core/prompt-engine",
    "platform-core/observability",
    "modules/creator-hub",
    "modules/ops-intelligence",
    "modules/knowledge-fabric"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --passWithNoTests",
    "build": "npm run build --workspaces --if-present",
    "smoke:ingestion": "bash scripts/smoke/ingestion-smoke.sh",
    "smoke:retrieval": "bash scripts/smoke/retrieval-smoke.sh",
    "smoke:generation": "bash scripts/smoke/grounded-generation-smoke.sh",
    "smoke:internal-auth": "bash scripts/smoke/internal-auth-smoke.sh"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0"
  },
  "volta": {
    "node": "20.20.0"
  }
}
